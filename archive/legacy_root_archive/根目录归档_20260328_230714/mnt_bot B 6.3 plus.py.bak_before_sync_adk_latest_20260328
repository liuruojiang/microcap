                us_sig_text = "; ".join(f"{_ROT_PROXY_TO_LIVE.get(e,e)} {_us_sig_w.get(e,0):.0%}" for e in sorted(_us_all_etfs) if _us_sig_w.get(e, 0) > 0.005)
