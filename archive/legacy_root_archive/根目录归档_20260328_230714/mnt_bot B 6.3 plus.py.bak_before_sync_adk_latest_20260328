                            _us_avail[a] = _mom_row[a]
                    _us_sorted = sorted(_us_avail.items(), key=lambda x: x[1], reverse=True)
                    _top3 = [a for a, _ in _us_sorted[:3]]
                    for _rank, (a, m) in enumerate(_us_sorted, 1):
                        _live = _ROT_PROXY_TO_LIVE.get(a, a)
