def _build_us_pnl_rows(strategy_records, price_df, proxy_map, end_date):
    if price_df is None or len(price_df) == 0:
        return []
    idx = price_df.index
    positions = {}
    rows = []
    for si, r in enumerate(strategy_records):
        td = pd.Timestamp(r.get("trade_date"))
        xd = (pd.Timestamp(strategy_records[si + 1].get("trade_date"))
              if si + 1 < len(strategy_records) else end_date)
        is_open = si + 1 >= len(strategy_records)
        qt = r.get("quantities", {}) or {}
        action = str(r.get("action", "")).lower()
        for etf, qty_val in qt.items():
            if etf == "_total" or isinstance(qty_val, dict):
                continue
            shares = _coerce_positive_number(qty_val)
            if shares is None:
                continue
            delta = -shares if action == "sell" else shares
            positions[etf] = positions.get(etf, 0.0) + delta
            if positions[etf] <= 1e-9:
                positions.pop(etf, None)
        ei = idx.searchsorted(td)
        xi = idx.searchsorted(xd, side='right') - 1
        if not (0 <= ei < len(idx) and 0 <= xi < len(idx) and xi >= ei):
            continue
        days = (idx[xi] - idx[ei]).days
        legs = []
        weights = _normalize_weight_map(r.get("weights", {}))
        exec_prices = r.get("exec_prices", {}) or {}
        if weights:
            for etf, wt in sorted(weights.items(), key=lambda x: -x[1]):
                market_ep = _price_at(price_df, ei, etf, proxy_map)
                xp = _price_at(price_df, xi, etf, proxy_map)
                ep = _coerce_positive_number(exec_prices.get(etf))
                if ep is None:
                    ep = market_ep
                if ep is None or xp is None:
                    continue
                ret = (xp / ep - 1) * 100
                legs.append({"etf": etf, "wt": wt, "ep": ep, "xp": xp,
                             "ret": ret, "contrib": ret * wt})
        else:
            seed = []
            total_value = 0.0
            for etf, shares in positions.items():
                market_ep = _price_at(price_df, ei, etf, proxy_map)
                xp = _price_at(price_df, xi, etf, proxy_map)
                ep = _coerce_positive_number(exec_prices.get(etf))
                if ep is None:
                    ep = market_ep
                if ep is None or xp is None:
                    continue
                value = shares * float(ep)
                if value <= 0:
                    continue
                seed.append((etf, ep, xp, value))
                total_value += value
            if total_value > 0:
                for etf, ep, xp, value in sorted(seed, key=lambda x: -x[3]):
                    wt = value / total_value
                    ret = (xp / ep - 1) * 100
                    legs.append({"etf": etf, "wt": wt, "ep": ep, "xp": xp,
                                 "ret": ret, "contrib": ret * wt})
        if legs:
            rows.append({"td": td, "xd": xd, "days": days,
                         "legs": legs,
                         "total": sum(l["contrib"] for l in legs),
                         "is_open": is_open})
    return rows

def _coerce_trade_shares(qty_val, exec_price=None):
    if isinstance(qty_val, dict):
        amt = _coerce_positive_number(qty_val.get("amount"))
        px = _coerce_positive_number(exec_price)
        if amt is None or px is None:
            return None
        return amt / px
    return _coerce_positive_number(qty_val)

def _build_us_holdings_pnl(strategy_records, price_df, proxy_map, end_date):
    if price_df is None or len(price_df) == 0:
        return None
    idx = price_df.index
    xi = idx.searchsorted(end_date, side='right') - 1
    if not (0 <= xi < len(idx)):
        return None

    positions = {}
    realized_pnl = 0.0
    for r in strategy_records:
        td = pd.Timestamp(r.get("trade_date"))
        ei = idx.searchsorted(td)
        if not (0 <= ei < len(idx)):
            continue
        action = str(r.get("action", "")).lower()
        exec_prices = r.get("exec_prices", {}) or {}
        qt = r.get("quantities", {}) or {}
        for etf, qty_val in qt.items():
            if etf == "_total":
                continue
            market_px = _price_at(price_df, ei, etf, proxy_map)
            trade_px = _coerce_positive_number(exec_prices.get(etf))
            if trade_px is None:
                trade_px = market_px
            shares = _coerce_trade_shares(qty_val, trade_px)
            if shares is None or shares <= 0 or trade_px is None or trade_px <= 0:
                continue
            pos = positions.setdefault(etf, {
                "shares": 0.0,
                "cost": 0.0,
                "buy_amount": 0.0,
                "buy_shares": 0.0,
                "last_trade_date": td,
            })
            pos["last_trade_date"] = td
            if action == "sell":
                if pos["shares"] <= 1e-9:
                    continue
                matched = min(shares, pos["shares"])
                avg_cost = pos["cost"] / pos["shares"] if pos["shares"] > 0 else 0.0
                realized_pnl += matched * (trade_px - avg_cost)
                pos["shares"] -= matched
                pos["cost"] -= matched * avg_cost
                if pos["shares"] <= 1e-9 or pos["cost"] <= 1e-9:
                    positions.pop(etf, None)
            else:
                pos["shares"] += shares
                pos["cost"] += shares * trade_px
                pos["buy_amount"] += shares * trade_px
                pos["buy_shares"] += shares

    legs = []
    total_value = 0.0
    total_cost = 0.0
    total_unrealized = 0.0
    asof = idx[xi]
    for etf, pos in positions.items():
        shares = pos["shares"]
        if shares <= 1e-9:
            continue
        current_px = _price_at(price_df, xi, etf, proxy_map)
        if current_px is None:
            continue
        avg_cost = pos["cost"] / shares if shares > 0 else None
        if avg_cost is None or avg_cost <= 0:
            continue
        market_value = shares * current_px
        unrealized = shares * (current_px - avg_cost)
        ret = (current_px / avg_cost - 1) * 100
        total_value += market_value
        total_cost += pos["cost"]
        total_unrealized += unrealized
        legs.append({
            "etf": etf,
            "shares": shares,
            "avg_cost": avg_cost,
            "current_px": current_px,
            "market_value": market_value,
            "unrealized": unrealized,
            "ret": ret,
            "last_trade_date": pos["last_trade_date"],
        })
    if not legs and abs(realized_pnl) < 1e-9:
        return None
    legs.sort(key=lambda x: -x["market_value"])
    total_ret = (total_unrealized / total_cost * 100) if total_cost > 0 else None
    return {
        "asof": asof,
        "legs": legs,
        "total_value": total_value,
        "total_cost": total_cost,
        "total_unrealized": total_unrealized,
        "total_ret": total_ret,
        "realized_pnl": realized_pnl,
    }

def _build_dk_pnl_rows(strategy_records, cn_dk_close, end_date):
    if cn_dk_close is None or len(cn_dk_close) == 0:
        return []
    dk_idx = cn_dk_close.index
    rows = []
    for si, r in enumerate(strategy_records):
        td = pd.Timestamp(r.get("trade_date"))
        xd = (pd.Timestamp(strategy_records[si + 1].get("trade_date"))
              if si + 1 < len(strategy_records) else end_date)
        is_open = si + 1 >= len(strategy_records)
        to_h = r.get("to_holding", "")
        ep_dict = r.get("exec_prices", {}) or {}
        qt_dict = r.get("quantities", {}) or {}
        raw_keys = list(dict.fromkeys(
            k for k in list(ep_dict.keys()) + list(qt_dict.keys()) if k != "_total"
        ))
        if not raw_keys:
            continue
        dk_dir = _get_dk_direction_labels(to_h, raw_keys)
        ei = dk_idx.searchsorted(td)
        xi = dk_idx.searchsorted(xd, side='right') - 1
        if not (0 <= ei < len(dk_idx) and 0 <= xi < len(dk_idx) and xi >= ei):
            continue
        days = (dk_idx[xi] - dk_idx[ei]).days
        legs = []
        seen_cols = set()
        for raw_key in raw_keys:
            col = _map_dk_key_to_close_col(raw_key)
            if not col or col in seen_cols or col not in cn_dk_close.columns:
                continue
            seen_cols.add(col)
            market_ep = cn_dk_close.iloc[ei][col]
            xp = cn_dk_close.iloc[xi][col]
            exec_ep = _coerce_positive_number(ep_dict.get(raw_key))
            ep = exec_ep if exec_ep is not None else market_ep
            if pd.isna(xp) or ep is None or ep <= 0:
                continue
            direction = dk_dir.get(raw_key, "")
            if not direction:
                direction = "做空" if _is_dk_short_text(raw_key) else "做多"
            price_chg = (xp / ep - 1) * 100
            is_short = _is_dk_short_text(direction) or _is_dk_short_text(raw_key)
            leg_ret = -price_chg if is_short else price_chg
            qty_val = qt_dict.get(raw_key)
            notional = None
            if isinstance(qty_val, dict) and "amount" in qty_val:
                notional = _coerce_positive_number(qty_val.get("amount"))
            elif isinstance(qty_val, (int, float)):
                notional = abs(float(qty_val)) * float(ep)
            legs.append({
                "name": CN_DK_NAMES.get(col, col),
                "direction": direction,
                "ep": ep,
                "xp": xp,
                "leg_ret": leg_ret,
                "notional": notional,
            })
        if legs:
            total_notional = sum(
                l["notional"] for l in legs
                if isinstance(l.get("notional"), (int, float)) and l["notional"] > 0
            )
            if total_notional > 0:
                total_ret = sum(l["leg_ret"] * l["notional"] for l in legs) / total_notional
            else:
                total_ret = sum(l["leg_ret"] for l in legs) / len(legs)
            rows.append({
                "ed": dk_idx[ei],
                "xd": dk_idx[xi],
                "days": days,
                "legs": legs,
                "total_ret": total_ret,
                "is_open": is_open,
            })
    return rows

