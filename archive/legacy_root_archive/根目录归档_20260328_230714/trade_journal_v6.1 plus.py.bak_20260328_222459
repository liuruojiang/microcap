    return _CN_HOLDING_NORM.get(name.lower().strip(), name)

# DK多空方向标签: 将to_holding中的名称与ep/qt的keys关联
_DK_NAME_GROUPS = [
    {"SZ50", "上证50", "DK_SZ50"},
    {"HS300", "沪深300"},
    {"ZZ500", "中证500"},
    {"ZZ1000", "中证1000", "DK_ZZ1000"},
    {"CYB", "CYB-ETF", "创业板"},
]
_DK_NAME_CANON = {}
for _grp in _DK_NAME_GROUPS:
    _fz = frozenset(_grp)
    for _nm in _grp:
        _DK_NAME_CANON[_nm] = _fz
del _grp, _fz, _nm

def _strip_dk_direction_prefix(text):
    s = str(text or "").strip()
    return re.sub(r"^(做多|做空|鍋氬|鍋氱┖|long|short)[_\\-\\s]*", "", s, flags=re.I)

def _is_dk_short_text(text):
    s = str(text or "").strip()
    lower = s.lower()
    return (
        s.startswith(("做空", "鍋氱┖")) or
        "做空" in s or
        "鍋氱┖" in s or
        "short" in lower
    )

def _get_dk_direction_labels(to_holding, keys):
    """从to_holding '做多X/做空Y' 解析方向, 映射到ep/qt的keys上."""
    m = re.match(r'做多(.+?)[/／]做空(.+)', to_holding or "")
    if not m:
        return {}
    long_name = m.group(1).strip()
    short_name = m.group(2).strip()
    long_group = _DK_NAME_CANON.get(long_name)
    short_group = _DK_NAME_CANON.get(short_name)
    result = {}
    for k in keys:
        k_raw = str(k or "").strip()
        k_clean = _strip_dk_direction_prefix(k_raw)
        k_group = _DK_NAME_CANON.get(k_clean)
        if k_raw.startswith(("做多", "鍋氬")) or k_raw.lower().startswith("long"):
            result[k] = "做多"
        elif k_raw.startswith(("做空", "鍋氱┖")) or k_raw.lower().startswith("short"):
            result[k] = "做空"
        elif k_clean == long_name or (k_group and long_group and k_group == long_group):
            result[k] = "做多"
        elif k_clean == short_name or (k_group and short_group and k_group == short_group):
            result[k] = "做空"
    return result

def _map_dk_key_to_close_col(key):
    if not key:
        return None
    if key in CN_DK_COLS:
        return key
    clean = _strip_dk_direction_prefix(key)
    alias = {
        "SZ50": "DK_SZ50",
        "HS300": "DK_HS300",
        "ZZ500": "DK_ZZ500",
        "ZZ1000": "DK_ZZ1000",
        "CYB": "DK_CYB",
        "CYB-ETF": "DK_CYB",
    }
    if clean in alias:
        return alias[clean]
    for col, name in CN_DK_NAMES.items():
        if clean == name:
            return col
    return None

def _coerce_positive_number(value):
    if isinstance(value, (int, float)):
        num = float(value)
    else:
        try:
            num = float(value)
        except (TypeError, ValueError):
            return None
    return num if num > 0 else None

def _normalize_weight_map(weights):
    norm = {}
    for k, v in (weights or {}).items():
        val = _coerce_positive_number(v)
        if val is None:
            continue
        norm[k] = val
    total = sum(norm.values())
    if total <= 0:
        return {}
    if abs(total - 1.0) > 1e-6:
        norm = {k: v / total for k, v in norm.items()}
    return norm

def _pick_price_col(asset, price_df, proxy_map):
    if asset == "EMXC" and US_ROT_EMXC_LIVE_COL in price_df.columns:
        return US_ROT_EMXC_LIVE_COL
    if asset in price_df.columns:
        return asset
    proxy = proxy_map.get(asset, asset)
    if proxy in price_df.columns:
        return proxy
    return None

def _price_at(price_df, idx_pos, asset, proxy_map):
    col = _pick_price_col(asset, price_df, proxy_map)
    if not col:
        return None
    px = price_df.iloc[idx_pos][col]
    if pd.isna(px) or px <= 0:
        return None
    return float(px)

