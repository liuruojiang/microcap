                xd_col = row["xd"].strftime('%Y-%m-%d') if is_first else ""
                days_col = str(row["days"]) if is_first else ""
                tot_col = total_str if is_first else ""
                st_col = status if is_first else ""
                w(f"| {n_col} | {ed_col} | {xd_col} | {days_col} "
                  f"| {leg['name']} | {d_icon} {leg['direction']} "
                  f"| {leg['ep']:,.0f} | {leg['xp']:,.0f} "
                  f"| {l_icon} {leg['leg_ret']:+.2f}% "
                  f"| {tot_col} | {st_col} |\n")
        w("\n")

    for strategy_name, price_df, proxy_map in [
        ("Sub-B", us_rot_close, _live_to_rot),
        ("Sub-C", us_prod_daily, _live_to_prod),
    ]:
        strategy_records = sorted(
            [r for r in records if r.get("strategy") == strategy_name
             and r.get("action") not in ("skip", "_deleted", "hold")],
            key=lambda r: (r.get("ts", ""), r.get("trade_date", ""), r.get("id", "")))
        summary = _build_us_holdings_pnl(strategy_records, price_df, proxy_map, end_date)
        if not summary:
            continue
        any_output = True
        asof_s = summary["asof"].strftime('%Y-%m-%d')
        w(f"#### {strategy_name} 当前持仓盈亏\n\n")
        w(f"> 截至: **{asof_s}**\n\n")
        w("| 标的 | 持仓股数 | 综合成本 | 最新价 | 浮盈亏 | 收益率 | 持仓市值 |\n")
        w("|:-|--------:|--------:|------:|------:|------:|--------:|\n")
        for leg in summary["legs"]:
            icon = "[+]" if leg["ret"] >= 0 else "[-]"
            w(f"| {leg['etf']} | {leg['shares']:,.0f} | "
              f"${leg['avg_cost']:,.2f} | ${leg['current_px']:,.2f} | "
              f"{icon} ${leg['unrealized']:+,.2f} | {icon} {leg['ret']:+.1f}% | "
              f"${leg['market_value']:,.2f} |\n")
        total_icon = "[+]" if summary["total_unrealized"] >= 0 else "[-]"
        total_ret = f"{summary['total_ret']:+.1f}%" if summary["total_ret"] is not None else "--"
        w(f"| **合计** | | | | **{total_icon} ${summary['total_unrealized']:+,.2f}** | "
          f"**{total_icon} {total_ret}** | **${summary['total_value']:,.2f}** |\n")
        if abs(summary["realized_pnl"]) > 1e-9:
            real_icon = "[+]" if summary["realized_pnl"] >= 0 else "[-]"
            w(f"\n> 期间已实现盈亏: **{real_icon} ${summary['realized_pnl']:+,.2f}**\n")
        w("\n")

    if not any_output:
        w("_\u65e0\u53ef\u8ba1\u7b97\u7684\u6301\u4ed3\u76c8\u4e8f\u6570\u636e\uff0c\u8bf7\u786e\u4fdd\u4ea4\u6613\u8bb0\u5f55\u4e2d\u5305\u542b\u6807\u7684\u4fe1\u606f\u3002_\n\n")

def _write_holding_pnl(w, records, cn_close, cn_dk_close, us_rot_close, us_prod_daily, end_date):
    """Write per-holding-segment P&L sections for all strategies."""
    return _write_holding_pnl_v2(
        w, records, cn_close, cn_dk_close, us_rot_close, us_prod_daily, end_date
    )
    _live_to_rot = {v: k for k, v in _ROT_PROXY_TO_LIVE.items()}
    _live_to_prod = {n: c["proxy"] for n, c in PROD_PORTFOLIO.items()}
    any_output = False

    # ── Sub-A ──
    sub_a = sorted(
        [r for r in records if r.get("strategy") == "Sub-A"
         and r.get("action") not in ("skip", "_deleted", "hold")],
        key=lambda r: r.get("trade_date", ""))
    if sub_a:
        cn_idx = cn_close.index
        rows = []
        for si, r in enumerate(sub_a):
            code = _normalize_cn_holding(r.get("to_holding"))
            name = CN_NAMES.get(code, r.get("to_holding", "?"))
            td = pd.Timestamp(r.get("trade_date"))
            xd = (pd.Timestamp(sub_a[si + 1].get("trade_date"))
                  if si + 1 < len(sub_a) else end_date)
            is_open = si + 1 >= len(sub_a)
            if code and code != "cash" and code in cn_close.columns:
                ei = cn_idx.searchsorted(td)
                xi = cn_idx.searchsorted(xd, side='right') - 1
                if 0 <= ei < len(cn_idx) and 0 <= xi < len(cn_idx) and xi >= ei:
                    ep = cn_close.iloc[ei][code]
                    xp = cn_close.iloc[xi][code]
                    if pd.notna(ep) and pd.notna(xp) and ep > 0:
                        ret = (xp / ep - 1) * 100
                        days = (cn_idx[xi] - cn_idx[ei]).days
                        rows.append({"name": name, "ed": cn_idx[ei], "xd": cn_idx[xi],
                                     "days": days, "ep": ep, "xp": xp,
                                     "ret": ret, "is_open": is_open})
            elif code == "cash":
                days = max((xd - td).days, 0)
                ret = ((1 + CN_RF_DAILY) ** days - 1) * 100
                rows.append({"name": "Cash", "ed": td, "xd": xd,
                             "days": days, "ep": None, "xp": None,
                             "ret": ret, "is_open": is_open})
        if rows:
            any_output = True
            w("#### Sub-A 逐笔盈亏\n\n")
            w("| # | 标的 | 入场日 | 出场日 | 天数 | 入场价 | 出/现价 | 收益率 | 状态 |\n")
            w("|:-|:-|:-|:-|------:|------:|------:|------:|:-|\n")
            for i, row in enumerate(rows):
                icon = "🟢" if row["ret"] >= 0 else "🔴"
                status = "📊 持有中" if row["is_open"] else "已平仓"
                ep_s = f"{row['ep']:.3f}" if row["ep"] is not None else "—"
                xp_s = f"{row['xp']:.3f}" if row["xp"] is not None else "—"
                ed_s = row["ed"].strftime('%Y-%m-%d') if hasattr(row["ed"], 'strftime') else str(row["ed"])[:10]
                xd_s = row["xd"].strftime('%Y-%m-%d') if hasattr(row["xd"], 'strftime') else str(row["xd"])[:10]
                w(f"| {i + 1} | {row['name']} | {ed_s} | {xd_s} | {row['days']} | "
                  f"{ep_s} | {xp_s} | {icon} {row['ret']:+.2f}% | {status} |\n")
            w("\n")

    # ── Sub-A-DK ──
    dk_recs = sorted(
        [r for r in records if r.get("strategy") == "Sub-A-DK"
         and r.get("action") not in ("skip", "_deleted", "hold")],
        key=lambda r: r.get("trade_date", ""))
