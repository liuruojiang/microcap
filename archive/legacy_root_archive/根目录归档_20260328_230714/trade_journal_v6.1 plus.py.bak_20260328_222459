def _parse_trade_csv_text(text):
    import csv as _csv

    _cn_to_action = {v: k for k, v in _ACTION_CN_MAP.items()}
    _cn_to_action["建仓"] = "buy"
    reader = _csv.DictReader(io.StringIO(text))
    imported = []
    errors = []
    for i, row in enumerate(reader, start=2):
        strategy = str(_csv_row_get(row, "策略", "strategy") or "").strip()
        action_cn = str(_csv_row_get(row, "操作", "action") or "").strip()
        if not strategy or not action_cn:
            continue
        action = _cn_to_action.get(action_cn, action_cn)

        ep = {}
        qt = {}
        wt = {}
        ep_raw = str(_csv_row_get(row, "执行价格", "exec_prices") or "").strip()
        qt_raw = str(_csv_row_get(row, "数量", "quantities") or "").strip()
        wt_raw = str(_csv_row_get(row, "权重", "weights") or "").strip()

        try:
            if ep_raw:
                ep = json.loads(ep_raw)
        except json.JSONDecodeError:
            errors.append(f"第{i}行: 执行价格JSON解析失败")
        try:
            if qt_raw:
                qt = json.loads(qt_raw)
        except json.JSONDecodeError:
            errors.append(f"第{i}行: 数量JSON解析失败")

        if strategy == "Sub-A-DK":
            ep = {re.sub(r"^(做多|做空)", "", k): v for k, v in ep.items()}
            qt = {re.sub(r"^(做多|做空)", "", k): v for k, v in qt.items()}

        if wt_raw:
            try:
                wt = json.loads(wt_raw)
            except json.JSONDecodeError:
                for part in re.split(r"[,，]", wt_raw):
                    part = part.strip()
                    if ":" not in part:
                        continue
                    k, v = part.split(":", 1)
                    v = v.strip().rstrip("%")
                    try:
                        wt[k.strip()] = float(v) / 100
                    except ValueError:
                        continue

        comm = {}
        comm_amt = str(_csv_row_get(row, "交易成本", "commission_amount") or "").strip().replace(",", "")
        comm_rate = str(_csv_row_get(row, "费率(‰)", "费率", "commission_rate") or "").strip()
        if comm_amt:
            try:
                comm["amount"] = float(comm_amt)
            except ValueError:
                pass
        if comm_rate:
            try:
                comm["rate"] = float(comm_rate) / 1000
            except ValueError:
                pass

        rec = {
            "id": str(_csv_row_get(row, "ID", "id") or "").strip(),
            "trade_date": str(_csv_row_get(row, "交易日期", "trade_date") or "").strip() or None,
            "ts": str(_csv_row_get(row, "记录时间", "ts") or "").strip() or None,
            "strategy": strategy,
            "action": action,
            "from_holding": str(_csv_row_get(row, "原持仓", "from_holding") or "").strip() or None,
            "to_holding": str(_csv_row_get(row, "新持仓", "to_holding") or "").strip(),
            "exec_prices": ep,
            "quantities": qt,
            "weights": wt if wt else {},
            "commission": comm if comm else {},
            "signal_followed": _parse_signal_followed_value(
                _csv_row_get(row, "跟随信号", "signal_followed")
            ),
            "notes": str(_csv_row_get(row, "备注", "notes") or "").strip() or None,
        }
        rec = {k: v for k, v in rec.items() if v is not None}
        imported.append(rec)

    if not imported:
        raise poe.BotError("CSV文件中未找到有效交易记录。请检查文件格式。")
    imported.sort(key=lambda r: (r.get("ts", ""), r.get("trade_date", ""), r.get("id", "")))
    return imported, errors

