                      f"| {leg['name']} | {d_icon} {leg['direction']} "
                      f"| {leg['ep']:,.0f} | {leg['xp']:,.0f} "
                      f"| {l_icon} {leg['leg_ret']:+.2f}% "
                      f"| {tot_col} | {st_col} |\n")
            w("\n")

    # ── Sub-B ──
    sub_b = sorted(
        [r for r in records if r.get("strategy") == "Sub-B"
         and r.get("action") not in ("skip", "_deleted", "hold")],
        key=lambda r: r.get("trade_date", ""))
    if sub_b:
        us_idx = us_rot_close.index
        rows = []
        for si, r in enumerate(sub_b):
            td = pd.Timestamp(r.get("trade_date"))
