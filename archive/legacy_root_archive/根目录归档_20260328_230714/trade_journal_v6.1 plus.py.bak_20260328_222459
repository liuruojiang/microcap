    def _handle_import_csv(self):
        import csv as _csv
        csv_att = None
        for att in poe.query.attachments:
            if att.name and att.name.lower().endswith('.csv'):
                csv_att = att
                break
        if not csv_att:
            raise poe.BotError("未检测到CSV文件。请附带 trade_log_*.csv 文件发送。")
        try:
            raw = csv_att.get_contents()
            # 尝试UTF-8 BOM / UTF-8 / GBK
            for enc in ("utf-8-sig", "utf-8", "gbk"):
                try:
                    text = raw.decode(enc)
                    break
                except UnicodeDecodeError:
                    continue
            else:
                raise poe.BotError("CSV文件编码无法识别，请使用UTF-8或GBK编码。")
        except Exception as e:
            if isinstance(e, poe.BotError):
                raise
            raise poe.BotError(f"CSV读取失败: {e}")
        # 反向操作映射: 中文→英文
        _cn_to_action = {v: k for k, v in _ACTION_CN_MAP.items()}
        _cn_to_action["建仓"] = "buy"
        reader = _csv.DictReader(io.StringIO(text))
        imported = []
        errors = []
        for i, row in enumerate(reader, start=2):
            strategy = (row.get("策略") or "").strip()
            action_cn = (row.get("操作") or "").strip()
            if not strategy or not action_cn:
                continue
            action = _cn_to_action.get(action_cn, action_cn)
            # 解析JSON字段
            ep = {}
            qt = {}
            wt = {}
            ep_raw = (row.get("执行价格") or "").strip()
            qt_raw = (row.get("数量") or "").strip()
            wt_raw = (row.get("权重") or "").strip()
            try:
                if ep_raw:
                    ep = json.loads(ep_raw)
            except json.JSONDecodeError:
                errors.append(f"第{i}行: 执行价格JSON解析失败")
            try:
                if qt_raw:
                    qt = json.loads(qt_raw)
            except json.JSONDecodeError:
                errors.append(f"第{i}行: 数量JSON解析失败")
            # DK: CSV导出时key带做多/做空前缀, 导入时去掉
            if strategy == "Sub-A-DK":
                ep = {re.sub(r'^(做多|做空)', '', k): v for k, v in ep.items()}
                qt = {re.sub(r'^(做多|做空)', '', k): v for k, v in qt.items()}
            # 权重: "BIL:31%, GLDM:17%" 格式 或 JSON
            if wt_raw:
                try:
                    wt = json.loads(wt_raw)
                except json.JSONDecodeError:
                    for part in wt_raw.split(","):
                        part = part.strip()
                        if ":" in part:
                            k, v = part.split(":", 1)
                            v = v.strip().rstrip("%")
                            try:
                                wt[k.strip()] = float(v) / 100
                            except ValueError:
                                pass
            # 手续费
            comm = {}
            comm_amt = (row.get("交易成本") or "").strip().replace(",", "")
            comm_rate = (row.get("费率(‰)") or "").strip()
            if comm_amt:
                try:
                    comm["amount"] = float(comm_amt)
                except ValueError:
                    pass
            if comm_rate:
                try:
                    comm["rate"] = float(comm_rate) / 1000
                except ValueError:
                    pass
            # 跟随信号
            sig_raw = (row.get("跟随信号") or "").strip()
            sig = True if sig_raw == "是" else (False if sig_raw == "否" else None)
            rec = {
                "id": (row.get("ID") or "").strip(),
                "trade_date": (row.get("交易日期") or "").strip() or None,
                "ts": (row.get("记录时间") or "").strip() or None,
                "strategy": strategy,
                "action": action,
                "from_holding": (row.get("原持仓") or "").strip() or None,
                "to_holding": (row.get("新持仓") or "").strip(),
                "exec_prices": ep,
                "quantities": qt,
                "weights": wt if wt else {},
                "commission": comm if comm else {},
                "signal_followed": sig,
                "notes": (row.get("备注") or "").strip() or None,
            }
            # 清理None值
            rec = {k: v for k, v in rec.items() if v is not None}
            imported.append(rec)
        if not imported:
            raise poe.BotError("CSV文件中未找到有效交易记录。请检查文件格式。")
        with _sm() as msg:
            w = msg.write
            w(f"## 📥 CSV导入交易记录\n\n")
            if errors:
                w(f"⚠️ {len(errors)} 个解析警告:\n")
                for e in errors[:5]:
                    w(f"- {e}\n")
                if len(errors) > 5:
                    w(f"- ...共 {len(errors)} 个\n")
                w("\n")
            w(f"成功导入 **{len(imported)}** 条记录:\n\n")
            strat_count = {}
            for r in imported:
                s = r.get("strategy", "?")
                strat_count[s] = strat_count.get(s, 0) + 1
            for s in ["Sub-A", "Sub-A-DK", "Sub-B", "Sub-C"]:
                if s in strat_count:
                    w(f"- {s}: {strat_count[s]}条\n")
            for r in imported:
                w(_build_trade_marker(r))
            w("\n发送 **\"交易记录\"** 查看所有记录")


