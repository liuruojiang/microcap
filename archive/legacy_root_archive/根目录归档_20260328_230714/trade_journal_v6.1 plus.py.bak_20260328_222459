                        comm_str += f" (回测假设{_theo_rate*1000:.1f}‰, 差{diff*1000:+.2f}‰)"
                    w(f"| 交易成本 | {comm_str} |\n")
                sig = rec["signal_followed"]
                w(f"| 跟随信号 | "
                          f"{'✅ 是' if sig is True else ('❌ 否' if sig is False else '—')}"
                          f" |\n")
                if rec["notes"]:
                    w(f"| 备注 | {rec['notes']} |\n")
                w(f"\n💡 如需修改，发送 \"删除记录 {rec['id']}\"\n")
                w(_build_trade_marker(rec))
    def _handle_delete_record(self, query):
        m = re.search(r'T\d{8}_\d{3}', query)
        if not m:
            raise poe.BotError("请提供记录ID，例如: 删除记录 T20260312_001")
        tid = m.group(0)
        existing = _scan_trade_logs(poe.default_chat)
        found = next((r for r in existing if r.get("id") == tid), None)
        if not found:
            raise poe.BotError(f"未找到记录 `{tid}`")
        del_rec = {"v": 1, "id": tid, "action": "_deleted",
                   "ts": beijing_now().isoformat()}
        act = _ACTION_CN_MAP.get(found.get("action", ""), found.get("action", ""))
        with _sm() as msg:
            w = msg.write
            w(f"## 🗑️ 记录已删除\n\n")
            w(f"- ID: `{tid}`\n")
            w(f"- 策略: {found.get('strategy', '?')} | "
                      f"操作: {act} | 持仓: {found.get('to_holding', '?')}\n")
            w(_build_trade_marker(del_rec))
    def _handle_trade_history(self):
        records = _scan_trade_logs(poe.default_chat)
        if not records:
            raise poe.BotError(
                "无记录。\n\n用自然语言记录交易，例如:\n"
                "- Sub-A换仓到ZZHL-ETF了\n"
                "- Sub-B调仓 QQQM 40% GLDM 30% IBIT 30%")
        with _sm() as msg:
            w = msg.write
            w(f"## 📋 交易记录 ({len(records)}条)\n\n")
            w("| # | 日期 | 策略 | 操作 | 详情 | 备注 |\n|:-|:-|:-|:-|:-|:-|\n")
            for i, r in enumerate(records, 1):
                act = _ACTION_CN_MAP.get(r.get("action", ""), r.get("action", ""))
                to_h = r.get("to_holding", "?")
                wts = r.get("weights", {})
                if wts:
                    parts = [f"{k}:{v:.0%}" for k, v in wts.items()
                             if isinstance(v, (int, float)) and v > 0.005]
                    if parts:
                        to_h = " ".join(parts)
                frm = r.get("from_holding", "")
                detail = f"{frm}->{to_h}" if frm and frm != to_h else to_h
                ep = r.get("exec_prices", {})
                if ep:
                    if r.get("strategy") == "Sub-A-DK":
                        _dk_d = _get_dk_direction_labels(
                            r.get("to_holding", ""), list(ep.keys()))
                        detail += " " + " ".join(
                            f"{'多' if _dk_d.get(k) == '做多' else '空' if _dk_d.get(k) == '做空' else ''}{k}@{v}"
                            for k, v in ep.items())
                    else:
                        detail += " " + " ".join(f"@{v}" for v in ep.values())
                sig = r.get("signal_followed")
                sig_i = " ✅" if sig is True else (
                    " ❌" if sig is False else "")
                notes = (r.get("notes", "") or "")[:20]
                w(f"| {i} | {r.get('trade_date', '?')} | "
                          f"{r.get('strategy', '?')} | {act}{sig_i} | "
                          f"{detail} | {notes} |\n")
            w("\n### 各策略持仓\n\n")
            latest = _get_latest_holdings(records)
            _net_pos = _compute_net_positions(records)
            for s in ["Sub-A", "Sub-A-DK", "Sub-B", "Sub-C"]:
                rec = latest.get(s)
                pos = _net_pos.get(s, {})
                if rec:
                    h = rec.get("to_holding")
                    # 当to_holding为null但净持仓仍存在时, 用净持仓修正显示
                    if not h and pos:
                        h = ", ".join(sorted(pos.keys()))
                    elif not h:
                        h = "已清仓"
                    wts = rec.get("weights", {})
                    if wts:
                        ws = ", ".join(
                            f"{k}:{v:.0%}" for k, v in wts.items()
                            if isinstance(v, (int, float)) and v > 0.005)
                        w(f"- **{s}**: {ws} "
                                  f"(记录于 {rec.get('trade_date', '?')})\n")
                    else:
                        w(f"- **{s}**: **{h}** "
                                  f"(记录于 {rec.get('trade_date', '?')})\n")
                else:
                    w(f"- **{s}**: _未记录_\n")
        cb = generate_trade_log_csv(records)
        fname = f"trade_log_{beijing_now().strftime('%Y%m%d')}.csv"
        with _sm() as msg:
            w = msg.write
            msg.attach_file(name=fname, contents=cb, content_type="text/csv")
            w(f"📎 **{fname}**")
    def _handle_live_portfolio(self, records=None, record_source=None, parse_errors=None):
        if records is None:
            records = _scan_trade_logs(poe.default_chat)
        latest = _get_latest_holdings(records)
        def _normalize_recorded_us_weights(weights):
            norm = {}
            if not isinstance(weights, dict):
                return norm
            for k, v in weights.items():
                if not isinstance(v, (int, float)) or v <= 0:
                    continue
                live = _ROT_PROXY_TO_LIVE.get(k, k)
                norm[live] = norm.get(live, 0.0) + float(v)
            total = sum(norm.values())
            if total <= 0:
                return {}
            if total < 0.995:
                norm["BIL"] = norm.get("BIL", 0.0) + max(1.0 - total, 0.0)
            elif total > 1.005:
                norm = {k: v / total for k, v in norm.items()}
            return norm
        if not records:
            raise poe.BotError(
                "无记录，无法显示实盘持仓。\n请先记录交易。")
        with _sm() as msg:
            w = msg.write
            if record_source:
                w(f"> 使用附件记录: **{record_source}** ({len(records)}条)\n")
                if parse_errors:
                    w(f"> CSV解析提示: {len(parse_errors)} 条，已忽略无法识别的字段。\n")
                w("\n")
            cn_close, cn_dk_close, us_rot_close, us_prod_daily = \
                self._fetch_data(msg)
            w("⏳ 正在计算策略信号...\n")
        d = self._compute_signal_data(
            cn_close, cn_dk_close, us_rot_close, us_prod_daily)
        # ─── 预先计算持仓明细 ───
        pos_config = _scan_position_config(poe.default_chat) or {}
        cap_config = _scan_capital_config(poe.default_chat) or {}
        detail = _build_holdings_detail(records, pos_config)
        # ── 用最新收盘价替换持仓成交价 ──
        _latest_close = {}
        # A股: 从已获取的cn_close取最新收盘
        if cn_close is not None and not cn_close.empty:
            for _secid, _name in CN_NAMES.items():
                if _secid in cn_close.columns:
                    _latest_close[_name] = float(cn_close[_secid].iloc[-1])
        # 美股: 从已获取的DataFrame取最新收盘(proxy tickers)
        for _df in [us_rot_close, us_prod_daily]:
            if _df is not None and not _df.empty:
                for _col in _df.columns:
                    _latest_close[_col] = float(_df[_col].iloc[-1])
        # 补充: proxy≠live的标的需额外获取(QQQM/GLDM/VGLT/PDBC/IBIT等)
        _need_fetch = set()
        for _s, _items in detail.items():
            if _s in ("Sub-B", "Sub-C"):
                for _it in _items:
                    if _it["name"] not in _latest_close:
                        _need_fetch.add(_it["name"])
        for _t in sorted(_need_fetch):
            _p, _ = _fetch_us_realtime_close(_t)
            if _p is not None:
                _latest_close[_t] = _p
            time.sleep(0.2)
        # 覆盖detail中的价格并重算金额
        for _s, _items in detail.items():
            for _it in _items:
                if _it["name"] in _latest_close:
                    _it["price"] = _latest_close[_it["name"]]
                    if _it.get("shares") is not None and _it["shares"] > 0:
                        _it["amount"] = _it["shares"] * _it["price"]
        b_rec = latest.get("Sub-B")
        b_rec_w = _normalize_recorded_us_weights(
            b_rec.get("weights", {}) if b_rec else {})
        b_items = list(detail.get("Sub-B", []))
        b_total_target = None
        b_pos_cfg = pos_config.get("Sub-B")
        if isinstance(b_pos_cfg, dict):
            _total_amount = b_pos_cfg.get("_total_amount")
            if isinstance(_total_amount, (int, float)) and _total_amount > 0:
                b_total_target = float(_total_amount)
        if b_total_target is None:
            _cap_amount = cap_config.get("Sub-B")
            if isinstance(_cap_amount, (int, float)) and _cap_amount > 0:
                b_total_target = float(_cap_amount)
        if b_rec_w:
            b_items_by_name = {it.get("name"): it for it in b_items if it.get("name")}
            known_amount = 0.0
            known_weight = 0.0
            for _name, _weight in b_rec_w.items():
                _item = b_items_by_name.get(_name)
                if _item and isinstance(_item.get("amount"), (int, float)) and _item["amount"] > 0:
                    known_amount += float(_item["amount"])
                    known_weight += float(_weight)
            total_b_amount = None
            if known_amount > 0 and known_weight > 0.001:
                total_b_amount = known_amount / known_weight
            elif b_total_target is not None:
                total_b_amount = b_total_target
            synth_b_items = []
            for _name, _weight in sorted(b_rec_w.items(), key=lambda x: (-x[1], x[0])):
                _price = _latest_close.get(_name)
                _amount = total_b_amount * _weight if total_b_amount is not None else b_items_by_name.get(_name, {}).get("amount")
                _shares = None
                if _amount is not None and _price and _price > 0:
                    _shares = int(_amount / _price)
                elif _name in b_items_by_name:
                    _shares = b_items_by_name[_name].get("shares")
                synth_b_items.append({
                    "name": _name,
                    "shares": _shares,
                    "price": _price,
                    "amount": _amount,
                    "direction": "",
                })
            detail["Sub-B"] = synth_b_items
        elif b_items and b_total_target is not None and not any(it.get("name") == "BIL" for it in b_items):
            risky_total = sum(float(it["amount"]) for it in b_items if isinstance(it.get("amount"), (int, float)) and it["amount"] > 0)
            bil_amount = b_total_target - risky_total
            if bil_amount > max(1.0, b_total_target * 0.005):
                bil_price = _latest_close.get("BIL")
                bil_shares = int(bil_amount / bil_price) if bil_price and bil_price > 0 else None
                b_items.append({
                    "name": "BIL",
                    "shares": bil_shares,
                    "price": bil_price,
                    "amount": bil_amount,
                    "direction": "",
                })
                detail["Sub-B"] = b_items
        with _sm() as msg:
            w = msg.write
            w("## 📊 实盘持仓 vs 理论持仓\n\n")
            # ── Sub-A ──
            w("### Sub-A\n\n| | 实际持仓 | 策略持仓 | 匹配 |\n|:-|:-|:-|:-|\n")
            if record_source:
                w(f"> 使用附件记录: **{record_source}** ({len(records)}条)\n")
                if parse_errors:
                    w(f"> CSV解析提示: {len(parse_errors)} 条，已忽略无法识别的字段。\n")
                w("\n")
            a_rec = latest.get("Sub-A")
            actual_a = a_rec.get("to_holding", "—") if a_rec else "—"
            theo_a_code = d["cn_current"]
            theo_a = CN_NAMES.get(theo_a_code, theo_a_code)
            if a_rec:
                match_a = ("✅" if _normalize_cn_holding(actual_a) == theo_a_code
