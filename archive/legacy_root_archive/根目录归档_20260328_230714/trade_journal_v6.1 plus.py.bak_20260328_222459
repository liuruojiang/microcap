def _compute_net_positions(records):
    """从交易记录计算各策略净持仓数量(买入累加, 卖出扣减).
    Returns: {strategy: {ticker: shares}}
    """
    positions = {}
    for r in records:
        s = r.get("strategy")
        if not s or r.get("action") in ("skip", "_deleted", "hold"):
            continue
        if s not in positions:
            positions[s] = {}
        qt = r.get("quantities", {})
        action = r.get("action", "")
        for k, v in qt.items():
            if k == "_total":
                continue
            if isinstance(v, dict):
                continue  # amount-based, skip
            shares = int(float(v)) if isinstance(v, (int, float)) else 0
            if shares <= 0:
                continue
            if k not in positions[s]:
                positions[s][k] = 0
            if action == "sell":
                positions[s][k] -= shares
            else:
                positions[s][k] += shares
        positions[s] = {k: v for k, v in positions[s].items() if v > 0}
    return positions

def _build_holdings_detail(records, pos_config=None):
    """从交易记录和仓位配置构建各策略持仓明细.

    策略: 累积所有交易记录中各标的的数量和成交价(后者覆盖前者),
    仓位配置(若有)优先于交易记录.

    Returns: {strategy: [{"name": str, "shares": int|None, "price": float|None,
                          "amount": float|None, "direction": str}, ...]}
    """
    pos_config = pos_config or {}

    # ── 1. 按策略累积所有记录的 qty/price ──
    accumulated = {}     # {strategy: {etf: {"qty": ..., "price": ...}}}
    latest_to_holding = {}  # {strategy: str}  最新 to_holding (用于DK方向)

    for r in records:
        s = r.get("strategy")
        if not s or r.get("action") in ("skip", "_deleted", "hold"):
            continue
        ep = r.get("exec_prices", {})
        qt = r.get("quantities", {})
        if s not in accumulated:
            accumulated[s] = {}
        latest_to_holding[s] = r.get("to_holding", "")
        is_sell = r.get("action") == "sell"

        for k in set(list(ep.keys()) + list(qt.keys())):
            if k == "_total":
                continue
            if k not in accumulated[s]:
                accumulated[s][k] = {}
            if k in qt:
                if is_sell and isinstance(qt[k], (int, float)):
                    # 卖出: 从累积数量中扣减
                    prev = accumulated[s][k].get("qty", 0)
                    if isinstance(prev, (int, float)):
                        accumulated[s][k]["qty"] = max(0, prev - qt[k])
                    else:
                        accumulated[s][k]["qty"] = qt[k]
                else:
                    # 买入/其他: 覆盖(代表新持仓数量)
                    accumulated[s][k]["qty"] = qt[k]
            if k in ep and isinstance(ep[k], (int, float)):
                accumulated[s][k]["price"] = ep[k]
        # 清理已完全卖出的标的(qty=0)
        if is_sell:
            accumulated[s] = {
                k: v for k, v in accumulated[s].items()
                if not (isinstance(v.get("qty"), (int, float)) and v["qty"] <= 0)
            }

    # ── 2. 构造各策略的持仓明细 ──
    def _make_item(name, qty_val, price, direction="", is_dk=False):
        """将 qty+price 转换为标准持仓条目. 金额 = 数量 × 价格/点位."""
        if isinstance(qty_val, dict) and "amount" in qty_val:
            amt = float(qty_val["amount"])
            shares = int(amt / price) if price and price > 0 else None
            return {"name": name, "shares": shares, "price": price,
                    "amount": amt, "direction": direction}
        elif isinstance(qty_val, (int, float)):
            shares = int(float(qty_val))
            amt = shares * price if isinstance(price, (int, float)) and price > 0 else None
            return {"name": name, "shares": shares, "price": price,
                    "amount": amt, "direction": direction}
        return None

    result = {}
    for s in ["Sub-A", "Sub-A-DK", "Sub-B", "Sub-C"]:
        pos = pos_config.get(s)
        acc = accumulated.get(s, {})
        is_dk = s == "Sub-A-DK"
        items = []

        # 收集所有价格（用于 pos_config 查价）
        all_prices = {k: v.get("price") for k, v in acc.items() if v.get("price") is not None}

        if pos and isinstance(pos, dict):
            # ── 仓位配置优先 ──
            dk_dir = {}
            if is_dk:
                for k in pos:
                    if k.startswith("做多_"):
                        dk_dir[k] = "做多"
                    elif k.startswith("做空_"):
                        dk_dir[k] = "做空"
                if not dk_dir:
                    dk_dir = _get_dk_direction_labels(
                        latest_to_holding.get(s, ""), list(pos.keys()))
            for etf, val in pos.items():
                name = etf.replace("做多_", "").replace("做空_", "")
                price = all_prices.get(name) or all_prices.get(etf)
                direction = dk_dir.get(etf, "")
                item = _make_item(name, val, price, direction, is_dk=is_dk)
                if item:
                    items.append(item)
        elif acc:
            # ── 从累积的交易记录获取 ──
            dk_dir = {}
            if is_dk:
                dk_dir = _get_dk_direction_labels(
                    latest_to_holding.get(s, ""), list(acc.keys()))
            for k, data in acc.items():
                p = data.get("price")
                q = data.get("qty")
                if q is None and p is None:
                    continue
                direction = dk_dir.get(k, "")
                item = _make_item(k, q, p, direction, is_dk=is_dk)
                if item:
                    items.append(item)
                elif p is not None:
                    # 只有价格无数量 — 仍然列出
                    items.append({"name": k, "shares": None, "price": p,
                                  "amount": None, "direction": direction})
        if items:
            result[s] = items
    return result

def _normalize_cn_holding(name):
    if name is None:
