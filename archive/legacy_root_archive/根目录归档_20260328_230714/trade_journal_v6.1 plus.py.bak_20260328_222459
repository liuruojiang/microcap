            dk_dir = _get_dk_direction_labels(to_h, raw_keys)
            ei = dk_idx.searchsorted(td)
            xi = dk_idx.searchsorted(xd, side='right') - 1
            if not (0 <= ei < len(dk_idx) and 0 <= xi < len(dk_idx) and xi >= ei):
                continue
            days = (dk_idx[xi] - dk_idx[ei]).days
            legs = []
            seen_cols = set()
