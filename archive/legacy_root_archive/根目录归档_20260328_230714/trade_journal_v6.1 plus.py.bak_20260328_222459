            weights = r.get("weights", {})
            if not weights:
                continue
            ei = us_idx.searchsorted(td)
            xi = us_idx.searchsorted(xd, side='right') - 1
            if not (0 <= ei < len(us_idx) and 0 <= xi < len(us_idx) and xi >= ei):
                continue
            days = (us_idx[xi] - us_idx[ei]).days
            legs = []
            for etf, wt in sorted(weights.items(), key=lambda x: -x[1]):
                if wt < 0.005:
