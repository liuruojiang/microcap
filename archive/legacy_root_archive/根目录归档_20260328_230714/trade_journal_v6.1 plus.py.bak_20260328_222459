            else:
                match_a = "未记录"
            w(f"| Sub-A | {actual_a} | {theo_a} | {match_a} |\n")
            # ── Sub-A-DK ──
            dk_rec = latest.get("Sub-A-DK")
            actual_dk = dk_rec.get("to_holding", "—") if dk_rec else "—"
            dk_pair = d.get("dk_top_pair", "")
            dk_dir_val = d.get("dk_direction", 0)
            if dk_pair and "/" in dk_pair:
                _dk_parts = dk_pair.split("/", 1)
